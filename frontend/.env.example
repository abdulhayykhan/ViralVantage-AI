# Next.js frontend environment variables (Vercel)
# Copy to .env.local and fill in your actual values

# API base URL for backend requests (e.g., https://your-backend.railway.app)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Supabase storage bucket for video uploads
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=creator_content
